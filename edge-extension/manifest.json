{
  "manifest_version": 3,
  "name": "📚 书籍简介文字处理工具",
  "short_name": "书籍文字处理",
  "description": "专为书籍简介文本快速格式化设计：关键词高亮、正则匹配、实时预览、一键生成 HTML 代码。配合 PoxenStudio/mybooks 项目使用。",
  "version": "2.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "书籍简介文字处理工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardWrite"
  ],
  "minimum_edge_version": "114.0.0"
}
